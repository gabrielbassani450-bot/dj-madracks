{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (Python http.server)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5173", "--directory", "site"],
      "port": 5173
    },
    {
      "name": "Static Site (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "site", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "Static Site (npx http-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "site", "-p", "8080", "-c-1"],
      "port": 8080
    }
  ]
}
